{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Hlavní oprávnění hlavního okna Weave (eventy, dialog, notifikace, otevírání odkazů).",
  "windows": [
    "main",
    "logs",
    "gallery"
  ],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "notification:allow-notify",
    "shell:allow-open",
    "updater:default",
    "process:allow-restart"
  ]
}
