{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Weave",
  "version": "0.1.0",
  "identifier": "dev.weave.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Weave",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/weave/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "publisher": "Elerdir",
    "category": "Productivity",
    "shortDescription": "AI chat s lokálními modely a generováním obrázků",
    "longDescription": "Weave je desktop AI chat aplikace: Mistral API i lokální GPU inference, generování obrázků přes ComfyUI s referencemi (PuLID), persony, export a fulltext historie.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Czech", "English"],
        "displayLanguageSelector": true
      },
      "wix": {
        "language": ["cs-CZ", "en-US"]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU3Qzc0OTkxRTFFRDkxMUUKUldRZWtlM2hrVW5IVndHSUlSV1p2ay9COWhLWG1aSVVHa05KMFE3VTdiMXZHSWZBTDVkNDh6dGkK",
      "endpoints": [
        "https://updates.weave.app/api/apps/weave/tauri/latest.json?channel=stable"
      ]
    }
  }
}
