  "query": "\n            SELECT wf.path, wf.name, wf.extension, wf.size_bytes, wf.modified_at,\n                   wf.indexed_at, wf.text_content\n            FROM workspace_files_fts fts\n            JOIN workspace_files wf ON wf.rowid = fts.rowid\n            WHERE workspace_files_fts MATCH ?\n            ORDER BY rank\n            LIMIT ?\n            ",
